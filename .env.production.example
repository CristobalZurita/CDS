# ==========================================
# CIRUJANO DE SINTETIZADORES - PRODUCTION CONFIG
# ==========================================
# DO NOT commit real values. Copy this file to .env and fill in secrets.
# Use `openssl rand -hex 64` to generate secure keys.

# ==========================================
# ENVIRONMENT
# ==========================================
ENVIRONMENT=production
DEBUG=false

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
POSTGRES_USER=cirujano_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=cirujano_prod_db
DATABASE_URL=postgresql://cirujano_prod:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/cirujano_prod_db

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# SECURITY - JWT (minimum 64 characters each, ALL DIFFERENT)
# Generate with: openssl rand -hex 64
# ==========================================
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_DIFFERENT_FROM_SECRET_KEY
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_HEX_DIFFERENT_FROM_JWT_SECRET

# ==========================================
# SECURITY - CSRF & API
# ==========================================
ENFORCE_CSRF=true
ALLOW_TOKEN_IN_RESPONSE=false
ENABLE_API_DOCS=false
ENABLE_PUBLIC_UPLOADS=false

# ==========================================
# CORS (your production domain)
# ==========================================
ALLOWED_ORIGINS=https://cirujanodesintetizadores.cl,https://www.cirujanodesintetizadores.cl

# ==========================================
# FRONTEND
# ==========================================
VITE_API_URL=https://cirujanodesintetizadores.cl/api/v1
VITE_ENVIRONMENT=production

# ==========================================
# PUBLIC URL (for emails, links, etc.)
# ==========================================
PUBLIC_BASE_URL=https://cirujanodesintetizadores.cl

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_HOST=mail.cirujanodesintetizadores.cl
SMTP_PORT=465
SMTP_USER=not-reply@cirujanodesintetizadores.cl
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_USE_TLS=false
SMTP_USE_SSL=true
FROM_EMAIL=not-reply@cirujanodesintetizadores.cl

# ==========================================
# WHATSAPP (optional)
# ==========================================
WHATSAPP_TOKEN=REPLACE_WITH_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=REPLACE_WITH_WHATSAPP_PHONE_ID
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANG=en_US

# ==========================================
# CLOUDFLARE TURNSTILE (optional)
# ==========================================
VITE_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY
TURNSTILE_DISABLE=false

# ==========================================
# CLAUDE AI (optional - image analysis)
# ==========================================
CLAUDE_API_KEY=REPLACE_WITH_CLAUDE_API_KEY

# ==========================================
# INSTRUMENT SYNC
# ==========================================
ENABLE_INSTRUMENT_AUTO_SYNC=true
INSTRUMENT_SYNC_ON_STARTUP=true
INSTRUMENT_SYNC_INTERVAL_MINUTES=360

# ==========================================
# FILE UPLOADS
# ==========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
