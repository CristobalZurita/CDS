# Environment Configuration
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=sqlite:///./diagnostic_system.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/diagnostic_db

# Application
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ENVIRONMENT=development

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# CORS
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
ALLOW_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_ENABLED=True
DIAGNOSTIC_RATE_LIMIT=5/hour
API_RATE_LIMIT=100/hour

# OpenCV Settings
OPENCV_DETECT_CIRCLES=True
OPENCV_MIN_CIRCLE_RADIUS=10
OPENCV_MAX_CIRCLE_RADIUS=50
OPENCV_MIN_DIST_BETWEEN_CIRCLES=30

# Pricing Configuration
BASE_DIAGNOSTIC_FEE=25000
FAULT_PRICE_BROKEN=15000
FAULT_PRICE_MISSING=20000
FAULT_PRICE_LOOSE=8000
FAULT_PRICE_NOISY=12000
FAULT_PRICE_STUCK=10000
FAULT_PRICE_OXIDIZED=18000

# Email Configuration (Optional - for notifications)
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Diagnostic System

# Frontend URLs
FRONTEND_URL=http://localhost:8080
DIAGNOSTIC_FORM_URL=http://localhost:8080/diagnostico
DASHBOARD_URL=http://localhost:8080/dashboard-tecnico

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# Logging
LOG_LEVEL=INFO
LOG_FILE=diagnostic_system.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Feature Flags
FEATURE_EMAIL_NOTIFICATIONS=False
FEATURE_PDF_GENERATION=False
FEATURE_PAYMENT_INTEGRATION=False
FEATURE_ML_DETECTION=False

# Cache (Optional - Redis)
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Monitoring (Optional - Sentry)
SENTRY_ENABLED=False
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# Backup
BACKUP_ENABLED=True
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups
