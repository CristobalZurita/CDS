# ==========================================
# CIRUJANO DE SINTETIZADORES - CONFIG
# ==========================================

# API Configuration
DEBUG=true
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=sqlite:///./cirujano.db

# Security - JWT Configuration
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_HEX
ALLOW_TOKEN_IN_RESPONSE=false
ENABLE_API_DOCS=false
ENABLE_PUBLIC_UPLOADS=false

# CORS Configuration (Frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://0.0.0.0:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://0.0.0.0:5173

# Email Configuration (for notifications)
SMTP_HOST=mail.cirujanodesintetizadores.cl
SMTP_SERVER=mail.cirujanodesintetizadores.cl
SMTP_PORT=465
SMTP_USER=not-reply@cirujanodesintetizadores.cl
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_USE_TLS=false
SMTP_USE_SSL=true
FROM_EMAIL=not-reply@cirujanodesintetizadores.cl
SMTP_FROM_EMAIL=not-reply@cirujanodesintetizadores.cl

# Public URLs and security toggles
PUBLIC_BASE_URL=http://localhost:8000
ENFORCE_CSRF=false
RATE_LIMIT_STORAGE_URI=memory://
REDIS_URL=

# Instrument sync
ENABLE_INSTRUMENT_AUTO_SYNC=true
INSTRUMENT_SYNC_ON_STARTUP=true
INSTRUMENT_SYNC_INTERVAL_MINUTES=360

# Claude AI Configuration (for image analysis)
# ⚠️ Legacy placeholder: actualmente no hay lectura activa de CLAUDE_API_KEY en el runtime.
CLAUDE_API_KEY=REPLACE_WITH_CLAUDE_API_KEY

# SendGrid Configuration (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cirujanodesintetizadores.cl

# Google Calendar (optional)
GOOGLE_CALENDAR_CREDENTIALS_FILE=./backend/credentials/google-calendar-credentials.json
GOOGLE_CALENDAR_ID=primary

# Storage Configuration
# ⚠️ Legacy placeholders: el runtime actual usa IMAGE_MAX_SIZE y rutas fijas de uploads.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB en bytes
IMAGE_MAX_SIZE=5242880
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
LOG_LEVEL=INFO
LOG_FILE=cirujano.log
INVENTORY_EXCEL_PATH=./Inventario_Cirujanosintetizadores.xlsx
IMPORT_DB_PATH=./backend/instance/cirujano.sqlite
KICAD_SYMBOLS_PATH=/usr/share/kicad/symbols

VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_VERSION=1.0.0
VITE_ANALYTICS_MODE=dev
VITE_ANALYTICS_URL=
VITE_GA_ID=

# Cloudflare Turnstile
VITE_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
VITE_TURNSTILE_DISABLE=true
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY

TURNSTILE_DISABLE=true

WHATSAPP_TOKEN=REPLACE_WITH_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=REPLACE_WITH_WHATSAPP_PHONE_ID
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANG=en_US

# Seed scripts (optional, solo si quieres credenciales determinísticas en scripts backend)
SEED_ADMIN_PASSWORD=
SEED_TEST_PASSWORD=

# ==========================================
# CLOUDINARY CONFIGURATION (ADITIVO)
# ==========================================
# Opción A: URL completa (recomendada)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Opción B: Variables separadas (alternativa)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Carpeta base en Cloudinary donde están las imágenes
CLOUDINARY_FOLDER_BASE=cirujano
