Ejecutar en orden después de las tareas anteriores:

# Paso 1: seed
cd backend && python scripts/seed_admin.py

# Paso 2: test login
curl -s -X POST http://localhost:8000/api/v1/auth/login \
  -H "Content-Type: application/json" \
  -d '{"email":"admin@test.com","password":"admin123"}' | python3 -m json.tool

# Paso 3: guardar token y testear /me
TOKEN=$(curl -s -X POST http://localhost:8000/api/v1/auth/login \
  -H "Content-Type: application/json" \
  -d '{"email":"admin@test.com","password":"admin123"}' | python3 -c "import sys,json; print(json.load(sys.stdin)['access_token'])")

curl -s http://localhost:8000/api/v1/auth/me \
  -H "Authorization: Bearer $TOKEN" | python3 -m json.tool

# Resultado esperado /me:
# { "id": 1, "email": "admin@test.com", "username": "admin", "role": "admin", ... }

