{
  "name": "cirujano-front",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src tests --ext .js,.ts,.vue",
    "test": "vitest --environment jsdom",
    "test:integration": "vitest run tests/integration --environment jsdom",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --config vitest.config.ts --environment jsdom --coverage",
    "e2e:seed-users": "backend/.venv/bin/python scripts/e2e/seed_users.py",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "build:email:styles": "sass src/scss/email.scss backend/app/static/email.css --no-source-map --style=expanded",
    "build": "npm run build:email:styles && vite build",
    "preview": "vite preview",
    "ghdeploy": "vite build && cd dist && cp index.html 404.html",
    "sync:instruments": "python3 scripts/sync_instruments.py",
    "sync:instruments:force": "python3 scripts/sync_instruments.py --force",
    "sync:instruments:once": "python3 scripts/auto_sync.py --once",
    "sync:instruments:watch": "python3 scripts/auto_sync.py --watch --watch-seconds 30",
    "sync:instruments:auto": "python3 scripts/auto_sync.py --daemon --interval-minutes 360",
    "validate:instruments": "python3 scripts/validate_instruments_sync.py --expected-fotos 249",
    "check:styles": "bash scripts/check_styles_compliance.sh",
    "check:api-layer": "bash scripts/check_api_layer_compliance.sh"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fortawesome/fontawesome-free": "^6.4.0",
    "@popperjs/core": "^2.11.7",
    "axios": "^1.13.6",
    "bootstrap": "^5.2.3",
    "dompurify": "^3.3.2",
    "emailjs": "^4.0.3",
    "gh-pages": "^6.3.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "swiper": "^12.1.2",
    "vue": "^3.2.47",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "critters": "^0.0.25",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "happy-dom": "^20.6.1",
    "jsdom": "^27.4.0",
    "sass": "^1.62.1",
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "typescript": "^5.2.2",
    "vite": "^6.2.5",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0"
  }
}
